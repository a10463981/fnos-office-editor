#!/bin/bash
# ============================================================================
# OfficeEditor - install_callback
# 安装后：部署二进制 + 创建 systemd 服务
# ============================================================================
set -e

echo "[OfficeEditor] 开始配置..."

TRIM_APPDEST="${TRIM_APPDEST:-/var/apps/OfficeEditor/target}"
SERVICE_NAME="officeeditor-connector"

# 1. 部署连接器二进制
echo "[OfficeEditor] 部署连接器..."
cp "$TRIM_APPDEST/connector/officeeditor-connector" /usr/local/bin/officeeditor-connector
chmod +x /usr/local/bin/officeeditor-connector
echo "[OfficeEditor] 连接器已部署"

# 2. 生成随机 JWT 密钥
JWT_SECRET=$(openssl rand -hex 32 2>/dev/null || echo "change-me-please-$(date +%s)")

# 3. 创建 systemd 服务（用环境变量传参）
cat > "/etc/systemd/system/$SERVICE_NAME.service" << EOF
[Unit]
Description=FNos OfficeEditor Connector
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/officeeditor-connector --port 10088
Restart=always
RestartSec=10
Environment=JWT_SECRET=$JWT_SECRET
Environment=BASE_URL=http://localhost:10088
Environment=TRIM_PKGVAR=${TRIM_PKGVAR:-/var/apps/OfficeEditor/var}

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload
systemctl enable "$SERVICE_NAME" 2>/dev/null || true
echo "[OfficeEditor] systemd 服务已创建"

# 4. 尝试启动连接器（忽略错误，用户可能会调整配置）
systemctl start "$SERVICE_NAME" 2>/dev/null || echo "  (连接器将在系统重启后自动启动)"

echo "[OfficeEditor] 安装完成!"
echo ""
echo "==========================================="
echo "  后续手动操作："
echo "  1. 启动 OnlyOffice:"
echo "     cd $TRIM_APPDEST/app/docker"
echo "     docker compose up -d"
echo ""
echo "  2. 启动连接器:"
echo "     systemctl start $SERVICE_NAME"
echo ""
echo "  3. 验证:"
echo "     curl http://localhost:10088/health"
echo "==========================================="

exit 0
