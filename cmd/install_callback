#!/bin/bash
# ============================================================================
set -e
# OfficeEditor - install_callback  
# ============================================================================

echo "[OfficeEditor] 开始配置..."

TRIM_APPDEST="${TRIM_APPDEST:-/var/apps/OfficeEditor/target}"
SERVICE_NAME="officeeditor-connector"

# 1. 部署连接器二进制
echo "[OfficeEditor] 部署连接器..."
cp "$TRIM_APPDEST/connector/officeeditor-connector" /usr/local/bin/officeeditor-connector 2>/dev/null || \
  install -m 755 "$TRIM_APPDEST/connector/officeeditor-connector" /usr/local/bin/officeeditor-connector
chmod +x /usr/local/bin/officeeditor-connector 2>/dev/null || true

# 2. 生成随机 JWT 密钥
JWT_SECRET=$(openssl rand -hex 32 2>/dev/null || echo "change-me-$(date +%s)")
export JWT_SECRET

# 3. 添加 docker 组
gpasswd -a admin docker 2>/dev/null || usermod -aG docker admin 2>/dev/null || true

# 4. 启动 OnlyOffice
echo "[OfficeEditor] 启动 OnlyOffice Document Server (端口 9080)..."
COMPOSE_DIR="$TRIM_APPDEST/docker"
echo "[OfficeEditor] COMPOSE_DIR=$COMPOSE_DIR"
ls -la "$COMPOSE_DIR/" 2>/dev/null || echo "[OfficeEditor] 目录不存在!"
if [ -f "$COMPOSE_DIR/docker-compose.yaml" ]; then
  cd "$COMPOSE_DIR"
  echo "[OfficeEditor] 拉取 OnlyOffice 镜像..."
  docker compose pull -q 2>/dev/null || docker compose pull 2>&1 | tail -3 || true
  echo "[OfficeEditor] 启动容器..."
  docker compose up -d --force-recreate 2>&1 || echo "[OfficeEditor] Docker 启动失败，请手动检查"
else
  echo "[OfficeEditor] 警告: docker-compose.yaml 不存在于 $COMPOSE_DIR"
  find /var/apps/OfficeEditor -name "docker-compose.yaml" 2>/dev/null
fi

# 5. 配置 FNos nginx 代理（支持 fnconnect/公网/内网 全场景）
echo "[OfficeEditor] 配置 nginx 代理..."
# 5a. OnlyOffice Document Server 代理（端口 9080 -> /officeds/）
cat > "/usr/trim/nginx/conf/conf.d/officeeditor-officeds.conf" << 'NGXEOF'
location ^~ /officeds/ {
   proxy_pass http://127.0.0.1:9080/;
   proxy_set_header Host $host;
   proxy_set_header X-Real-IP $remote_addr;
   proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
   proxy_http_version 1.1;
   proxy_set_header Upgrade $http_upgrade;
   proxy_set_header Connection $connection_upgrade;
}
NGXEOF

# 5b. 连接器 API 代理（端口 10088 -> /officeeditor-api/）
#     所有场景通过 nginx 统一入口，浏览器不用直接连 10088 端口
cat > "/usr/trim/nginx/conf/conf.d/officeeditor-api.conf" << 'NGXEOF'
location ^~ /officeeditor-api/ {
	   proxy_set_header X-Trim-UserID $http_x_trim_userid;
	   proxy_set_header X-Trim-Username $http_x_trim_username;
	   proxy_set_header X-Trim-IsAdmin $http_x_trim_isadmin;
   proxy_pass http://127.0.0.1:10088/;
   proxy_set_header Host $host;
   proxy_set_header X-Real-IP $remote_addr;
   proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
   proxy_set_header X-Forwarded-Proto $scheme;
   proxy_http_version 1.1;
   proxy_read_timeout 120s;
}
NGXEOF

/usr/trim/nginx/sbin/nginx -s reload 2>/dev/null || true
echo "[OfficeEditor] nginx 代理已配置:"
echo "  /officeds/     ---> 127.0.0.1:9080 (OnlyOffice)"
echo "  /officeeditor-api/ --> 127.0.0.1:10088 (连接器 API)"

# 6. 创建 systemd 服务
echo "[OfficeEditor] 创建 systemd 服务..."

# 尝试获取 NAS 的 LAN IP 作为默认 BASE_URL
NAS_LAN_IP=""
if command -v ip &>/dev/null; then
  NAS_LAN_IP=$(ip -4 route get 1 2>/dev/null | head -1 | awk '{print $7}')
fi
if [ -z "$NAS_LAN_IP" ]; then
  NAS_LAN_IP="localhost"
fi

cat > "/etc/systemd/system/$SERVICE_NAME.service" << EOF
[Unit]
Description=FNos OfficeEditor Connector
After=network.target docker.service
Wants=docker.service

[Service]
Type=simple
ExecStart=/usr/local/bin/officeeditor-connector --port 10088
Restart=always
RestartSec=10
EnvironmentFile=-/etc/default/officeeditor-connector
Environment=JWT_SECRET=$JWT_SECRET
Environment=BASE_URL=http://${NAS_LAN_IP}:10088
Environment=PUBLIC_BASE_URL=
Environment=TRIM_PKGVAR=${TRIM_PKGVAR:-/var/apps/OfficeEditor/var}

[Install]
WantedBy=multi-user.target
EOF

echo "[OfficeEditor] BASE_URL 已设为 http://${NAS_LAN_IP}:10088"
echo "[OfficeEditor] PUBLIC_BASE_URL 未设置（设为空，自动检测模式）"
echo "[OfficeEditor] 若使用 fnconnect 或公网访问，可在 /etc/default/officeeditor-connector 中设置 PUBLIC_BASE_URL"

systemctl daemon-reload
systemctl enable "$SERVICE_NAME" 2>/dev/null || true
systemctl start "$SERVICE_NAME" 2>/dev/null || true

# 7. 创建环境变量配置文件模板（便于用户自定义 PUBLIC_BASE_URL）
cat > "/etc/default/officeeditor-connector" << 'ENVEOF'
# OfficeEditor Connector 环境变量配置
# 此文件在 systemd 服务中通过 EnvironmentFile 加载，优先级高于单元文件
#
# 使用场景:
# 1. fnconnect 远程访问: 设置 PUBLIC_BASE_URL 为您的 Trim 域名
#    例如: PUBLIC_BASE_URL=https://xxxx.trim.com
# 2. DDNS/公网访问: 设置 PUBLIC_BASE_URL 为您的 DDNS 域名
#    例如: PUBLIC_BASE_URL=http://your-nas.abc.com:10088
# 3. NAT 穿透 (frp/ZeroTier): 设置 PUBLIC_BASE_URL 为穿透后的地址
#    例如: PUBLIC_BASE_URL=http://10.0.0.1:10088
#
# 留空或不设置 = 自动检测模式（基于请求的 Host header）
# PUBLIC_BASE_URL=

# JWT_SECRET 在安装时自动生成，如需覆盖可在此设置
# JWT_SECRET=your-custom-secret-here
ENVEOF
echo "[OfficeEditor] 环境变量配置文件已创建: /etc/default/officeeditor-connector"

echo "[OfficeEditor] 安装完成!"
echo "  连接器: http://localhost:10088/health"
echo "  OnlyOffice: http://localhost:9080/healthcheck"
echo ""
echo "==========================================="
echo "  office 协作 v1.0.02 - 基于 OnlyOffice"
echo "  GitHub: github.com/a10463981/fnos-office-editor"
echo "  欢迎赞助支持! (微信/支付宝见 README)"
echo "==========================================="
exit 0
