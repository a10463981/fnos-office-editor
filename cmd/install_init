#!/bin/bash
# ============================================================================
# OfficeEditor - install_init
# 在安装应用文件前执行
# ============================================================================

echo "[OfficeEditor] install_init: 开始安装前准备..."

# 检查系统架构
ARCH=$(uname -m)
case "$ARCH" in
    x86_64)  DS_ARCH="amd64" ;;
    aarch64) DS_ARCH="arm64" ;;
    *)
        echo "不支持的架构: $ARCH" > "$TRIM_TEMP_LOGFILE"
        exit 1
        ;;
esac
echo "[OfficeEditor] 系统架构: $ARCH"

# 检查 Docker 是否可用
if ! command -v docker &>/dev/null; then
    echo "Docker 未安装，正在安装 Docker..." > "$TRIM_TEMP_LOGFILE"
    curl -fsSL https://get.docker.com | sh
    systemctl enable docker
    systemctl start docker
fi

# 检查 docker compose 插件
if ! docker compose version &>/dev/null; then
    echo "Docker Compose 插件未安装" > "$TRIM_TEMP_LOGFILE"
    exit 1
fi

# 检查必要端口
for port in 10088 9080; do
    if ss -tlnp | grep -q ":$port "; then
        echo "端口 $port 已被占用" >> "$TRIM_TEMP_LOGFILE"
    fi
done

echo "[OfficeEditor] install_init: 检查完成"

exit 0
