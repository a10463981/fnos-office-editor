#!/bin/bash
# ============================================================================
# OfficeEditor - upgrade_init
# 升级前执行: 备份配置和数据
# ============================================================================
#set -e (removed for resilience)

echo "[OfficeEditor] upgrade_init: 备份配置..."

BACKUP_DIR="${TRIM_PKGVAR:-/var/apps/OfficeEditor/var}/backup/$(date +%Y%m%d_%H%M%S)"
mkdir -p "$BACKUP_DIR"

# 备份连接器配置
if [ -f "${TRIM_PKGETC:-/var/apps/OfficeEditor/etc}/config.json" ]; then
    cp "${TRIM_PKGETC:-/var/apps/OfficeEditor/etc}/config.json" "$BACKUP_DIR/"
    echo "[OfficeEditor] 配置已备份到 $BACKUP_DIR"
fi

exit 0
