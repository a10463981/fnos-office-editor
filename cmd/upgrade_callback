#!/bin/bash
# ============================================================================
set -e
# OfficeEditor - upgrade_callback
# 升级后执行: 更新连接器二进制, 重启服务
# ============================================================================

echo "[OfficeEditor] upgrade_callback: 应用升级..."

cp "${TRIM_APPDEST:-/var/apps/OfficeEditor/target}/connector/officeeditor-connector" /usr/local/bin/officeeditor-connector
chmod +x /usr/local/bin/officeeditor-connector

systemctl restart officeeditor-connector

# 更新 Docker 镜像
cd "${TRIM_APPDEST:-/var/apps/OfficeEditor/target}/docker"
docker compose pull
docker compose up -d

echo "[OfficeEditor] 升级完成"
exit 0
