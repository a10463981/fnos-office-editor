#!/bin/bash
# ============================================================================
# OfficeEditor - uninstall_callback
# 安全卸载: 用户确认后才删除
# ============================================================================
set -e

echo "[OfficeEditor] ===== 开始卸载 ====="

# 读取用户选择（由 wizard 勾选决定）
REMOVE_DOCKER="${REMOVE_DOCKER:-true}"
REMOVE_DATA="${REMOVE_DATA:-true}"

# 1. 清理 OnlyOffice Docker（精确名称，不用通配符）
if [ "$REMOVE_DOCKER" = "true" ]; then
  echo "[OfficeEditor] 清理 Docker..."
  
  # 先尝试 compose down（如果有 compose 文件）
  COMPOSE_DIR="${TRIM_APPDEST:-/var/apps/OfficeEditor/target}/officeeditor-docker"
  if [ -f "$COMPOSE_DIR/docker-compose.yaml" ]; then
    cd "$COMPOSE_DIR" 2>/dev/null
    docker compose down -v --remove-orphans 2>/dev/null || true
  fi
  
  # 直接用精确名称确保安全
  docker stop  officeeditor-docserver  2>/dev/null || true
  docker rm -f officeeditor-docserver  2>/dev/null || true
  docker volume rm -f officeeditor-ds-cache  2>/dev/null || true
  docker volume rm -f officeeditor-ds-data   2>/dev/null || true
  docker volume rm -f officeeditor-ds-log    2>/dev/null || true
  docker volume rm -f officeeditor-ds-fonts  2>/dev/null || true
  
  echo "[OfficeEditor] Docker 已清理"
else
  echo "[OfficeEditor] 跳过 Docker 清理"
fi

# 2. 清理应用数据
if [ "$REMOVE_DATA" = "true" ]; then
  echo "[OfficeEditor] 清理应用数据..."
  
  # systemd 服务
  systemctl stop   officeeditor-connector 2>/dev/null || true
  systemctl disable officeeditor-connector 2>/dev/null || true
  rm -f /etc/systemd/system/officeeditor-connector.service
  systemctl daemon-reload 2>/dev/null || true
  
  # 二进制
  rm -f /usr/local/bin/officeeditor-connector 2>/dev/null || true
  
  # nginx 配置
  rm -f /usr/trim/nginx/conf/conf.d/officeeditor.conf       2>/dev/null || true
  rm -f /usr/trim/nginx/conf/conf.d/officeeditor-officeds.conf 2>/dev/null || true
  rm -f /etc/nginx/conf.d/officeeditor.conf                 2>/dev/null || true
  rm -f /etc/nginx/sites-enabled/officeeditor.conf          2>/dev/null || true
  /usr/trim/nginx/sbin/nginx -s reload 2>/dev/null || nginx -s reload 2>/dev/null || true
  
  # 数据目录
  rm -rf "${TRIM_PKGVAR:-/var/apps/OfficeEditor/var}" 2>/dev/null || true
  rm -rf "${TRIM_PKGETC:-/var/apps/OfficeEditor/etc}" 2>/dev/null || true
  
  echo "[OfficeEditor] 应用数据已清理"
else
  echo "[OfficeEditor] 保留应用数据"
fi

echo "[OfficeEditor] ===== 卸载完成 ====="
exit 0
