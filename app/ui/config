{
  ".url": {
    "OfficeEditor.Application": {
      "title": "FNos 办公编辑器",
      "icon": "images/icon_{0}.png",
      "type": "iframe",
      "url": "/",
      "allUsers": true
    }
  },
  ".file": {
    "OfficeEditor.OpenDocument": {
      "title": "用 OnlyOffice 编辑",
      "type": "url",
      "url": "/editor?path={path}",
      "fileTypes": ["docx", "xlsx", "pptx"],
      "allUsers": true,
      "noDisplay": true
    },
    "OfficeEditor.OpenLegacyDocument": {
      "title": "用 OnlyOffice 打开",
      "type": "url",
      "url": "/editor?path={path}",
      "fileTypes": ["doc", "xls", "ppt"],
      "allUsers": true,
      "noDisplay": true
    },
    "OfficeEditor.OpenODF": {
      "title": "用 OnlyOffice 打开",
      "type": "url",
      "url": "/editor?path={path}",
      "fileTypes": ["odt", "ods", "odp"],
      "allUsers": true,
      "noDisplay": true
    },
    "OfficeEditor.ViewDocument": {
      "title": "用 OnlyOffice 预览",
      "type": "url",
      "url": "/editor?path={path}&mode=view",
      "fileTypes": ["pdf", "txt", "csv", "rtf", "epub"],
      "allUsers": true,
      "noDisplay": true
    }
  }
}
