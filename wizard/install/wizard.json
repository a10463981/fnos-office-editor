{
  "page": [
    {
      "id": "volumes",
      "title": "选择存储卷",
      "desc": "选择需要 OnlyOffice 访问的存储卷路径",
      "fields": [
        {
          "id": "volumes",
          "label": "存储卷路径",
          "type": "multiselect",
          "description": "选择 OnlyOffice 可以访问的存储卷",
          "options": [
            {"value": "/vol1", "label": "/vol1"},
            {"value": "/vol2", "label": "/vol2"},
            {"value": "/vol3", "label": "/vol3"}
          ],
          "required": true
        }
      ]
    },
    {
      "id": "network",
      "title": "网络配置",
      "desc": "配置内外网访问",
      "fields": [
        {
          "id": "base_url",
          "label": "内网地址",
          "type": "text",
          "default": "http://192.168.1.100:10099",
          "description": "内网访问连接器的地址"
        },
        {
          "id": "public_url",
          "label": "外网地址（可选）",
          "type": "text",
          "description": "远程访问的完整 URL，如 https://xxx.fnconnect.com/officeeditor"
        }
      ]
    },
    {
      "id": "confirm",
      "title": "确认安装",
      "desc": "确认以下信息并开始安装",
      "fields": [
        {
          "id": "preserve_data",
          "label": "卸载时保留数据",
          "type": "checkbox",
          "default": true,
          "description": "卸载应用时保留配置和文档数据"
        }
      ]
    }
  ]
}
